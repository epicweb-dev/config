{
  "$schema": "https://json.schemastore.org/package",
  "name": "@epic-web/config",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.0-semantically-released",
  "description": "Reasonable Oxlint, Prettier, and TypeScript configs for epic web devs",
  "main": "index.js",
  "type": "module",
  "imports": {
    "#/*": "./*"
  },
  "exports": {
    ".": "./index.js",
    "./prettier": "./prettier.js",
    "./typescript": "./typescript.json",
    "./reset.d.ts": "./reset.d.ts",
    "./oxlint": "./oxlint-config.json"
  },
  "prettier": "./prettier.js",
  "scripts": {
    "format": "prettier . --write",
    "lint": "oxlint --config oxlint-config.json .",
    "test": "vitest run lint-rules/*.test.js",
    "typecheck": "tsc",
    "validate": "run-p -l format lint typecheck"
  },
  "keywords": [
    "config",
    "oxlint",
    "prettier",
    "typescript",
    "epic"
  ],
  "author": "Kent C. Dodds <me@kentcdodds.com> (https://kentcdodds.com/)",
  "repository": {
    "type": "git",
    "url": "https://github.com/epicweb-dev/config"
  },
  "homepage": "https://github.com/epicweb-dev/config",
  "license": "MIT",
  "dependencies": {
    "@oxlint/plugins": "^1.43.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@types/react": "^19.1.8",
    "npm-run-all": "^4.1.5",
    "oxlint": "^1.57.0",
    "prettier": "^3.6.2",
    "react": "^19.1.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
